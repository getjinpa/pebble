---
interface Props { siteConfig: any; }
const { siteConfig } = Astro.props;
const artist = siteConfig.artist || {};
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span class="footer-name">{artist.name || siteConfig.site.title}</span>
    <span class="footer-copy">
      &copy; {year} &nbsp;·&nbsp;
      Built with <a href="https://getjinpa.com" target="_blank" rel="noopener noreferrer">Jinpa</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }

  .footer-copy {
    font-size: 0.8125rem;
    color: var(--ink-muted);
  }

  .footer-copy a {
    color: var(--ink-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-copy a:hover { color: var(--terracotta); }
</style>
