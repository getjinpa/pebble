---
import { withBase } from '../../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  siteConfig: any;
}

const { title, description, image, siteConfig } = Astro.props;

const siteTitle = siteConfig.site.title;
const siteDesc  = siteConfig.site.description;
const siteUrl   = (siteConfig.site.url || '').replace(/\/$/, '');

const pageTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const pageDesc  = description || siteDesc;
const ogImage   = image || siteConfig.seo?.ogImage || `${siteUrl}/og-default.jpg`;
const canonical = new URL(Astro.url.pathname, siteUrl || 'https://example.com').href;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<link rel="canonical" href={canonical} />

<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

<!-- Cormorant Garamond + Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Inter:wght@400;500;600&display=swap"
  rel="stylesheet"
/>

<meta property="og:type"        content="website" />
<meta property="og:url"         content={canonical} />
<meta property="og:title"       content={pageTitle} />
<meta property="og:description" content={pageDesc} />
<meta property="og:image"       content={ogImage} />
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={pageTitle} />
<meta name="twitter:description" content={pageDesc} />
<meta name="twitter:image"       content={ogImage} />
